
<div class="elanvi-account-dashboard">

  <nav class="elanvi-account-breadcrumb" aria-label="Breadcrumb">
    <a href="{{ routes.account_url }}">Account</a>
    <span aria-hidden="true">&rsaquo;</span>
    <span aria-current="page">Addresses</span>
  </nav>

  <div class="elanvi-account-dashboard__header">
    <h1 class="elanvi-heading-md">My Addresses</h1>
    <button
      class="elanvi-btn elanvi-btn--primary elanvi-btn--sm"
      type="button"
      aria-expanded="false"
      aria-controls="AddressNewForm"
      id="AddNewAddressBtn"
      onclick="this.setAttribute('aria-expanded', 'true'); document.getElementById('AddressNewForm').hidden = false; this.hidden = true;"
    >
      + Add Address
    </button>
  </div>

  {%- comment %} ── New Address Form ── {%- endcomment -%}
  <div id="AddressNewForm" class="elanvi-address-form-wrap" hidden>
    <div class="elanvi-address-form-card">
      <h2 class="elanvi-address-form-card__title">New Address</h2>
      {%- form 'customer_address', customer.new_address, class: 'elanvi-account-form' -%}
        {%- render 'address-fields', form: form, address: customer.new_address -%}
        <div class="elanvi-address-form__actions">
          <button type="submit" class="elanvi-btn elanvi-btn--primary">Save Address</button>
          <button
            type="button"
            class="elanvi-btn elanvi-btn--outline"
            onclick="document.getElementById('AddressNewForm').hidden = true; document.getElementById('AddNewAddressBtn').hidden = false;"
          >
            Cancel
          </button>
        </div>
      {%- endform -%}
    </div>
  </div>

  {%- comment %} ── Existing Addresses ── {%- endcomment -%}
  {%- if customer.addresses.size > 0 -%}
    <div class="elanvi-address-grid">
      {%- for address in customer.addresses -%}
        <div class="elanvi-address-card">
          {%- if address == customer.default_address -%}
            <span class="elanvi-address-card__default">Default</span>
          {%- endif -%}
          <address class="elanvi-address-card__body">
            <strong>{{ address.name }}</strong><br>
            {%- if address.company != blank -%}{{ address.company }}<br>{%- endif -%}
            {{ address.address1 }}<br>
            {%- if address.address2 != blank -%}{{ address.address2 }}<br>{%- endif -%}
            {{ address.city }}, {{ address.province_code }} {{ address.zip }}<br>
            {{ address.country_code }}
            {%- if address.phone != blank -%}<br>{{ address.phone }}{%- endif -%}
          </address>
          <div class="elanvi-address-card__actions">
            <button
              type="button"
              class="elanvi-address-card__edit-btn"
              aria-expanded="false"
              aria-controls="EditAddress_{{ address.id }}"
              onclick="
                var form = document.getElementById('EditAddress_{{ address.id }}');
                var expanded = this.getAttribute('aria-expanded') === 'true';
                this.setAttribute('aria-expanded', !expanded);
                form.hidden = expanded;
                this.textContent = expanded ? 'Edit' : '✕ Close';
              "
            >
              Edit
            </button>
            {%- unless address == customer.default_address -%}
              {%- form 'customer_address', address, class: 'elanvi-address-delete-form' -%}
                <input type="hidden" name="_method" value="delete">
                <button
                  type="submit"
                  class="elanvi-address-card__delete-btn"
                  onclick="return confirm('Delete this address?')"
                >
                  Delete
                </button>
              {%- endform -%}
            {%- endunless -%}
          </div>

          <div id="EditAddress_{{ address.id }}" class="elanvi-address-edit" hidden>
            {%- form 'customer_address', address, class: 'elanvi-account-form' -%}
              {%- render 'address-fields', form: form, address: address -%}
              <label class="elanvi-form__checkbox">
                <input
                  type="checkbox"
                  name="address[default]"
                  value="1"
                  {% if address == customer.default_address %}checked{% endif %}
                >
                Set as default address
              </label>
              <div class="elanvi-address-form__actions">
                <button type="submit" class="elanvi-btn elanvi-btn--primary">Update Address</button>
              </div>
            {%- endform -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- else -%}
    <div class="elanvi-account-empty">
      <p class="elanvi-account-empty__text">You have no saved addresses.</p>
    </div>
  {%- endif -%}

  <a href="{{ routes.account_url }}" class="elanvi-account-back">&larr; Back to account</a>

</div>

{% stylesheet %}
  .elanvi-account-dashboard {
    max-width: 900px;
    margin-inline: auto;
    padding: 2.5rem 1rem 4rem;
  }

  @media (min-width: 750px) {
    .elanvi-account-dashboard { padding: 3.5rem 1.5rem 5rem; }
  }

  .elanvi-account-breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--elanvi-text-muted, #5A5147);
    margin-bottom: 1.5rem;
  }

  .elanvi-account-breadcrumb a {
    color: var(--elanvi-gold, #B78A57);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .elanvi-account-dashboard__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .elanvi-btn--sm {
    padding: 0.5rem 1.25rem;
    font-size: 0.8125rem;
    min-height: 36px;
  }

  .elanvi-address-form-wrap { margin-bottom: 2rem; }

  .elanvi-address-form-card {
    background: var(--elanvi-white, #fff);
    border: 1px solid var(--elanvi-gold, #B78A57);
    border-radius: 16px;
    padding: 1.5rem;
    max-width: 540px;
  }

  .elanvi-address-form-card__title {
    font-family: var(--elanvi-font-serif, serif);
    font-size: 1.125rem;
    color: var(--elanvi-text, #2E2924);
    margin: 0 0 1.25rem;
  }

  .elanvi-account-form { display: flex; flex-direction: column; gap: 1rem; }

  .elanvi-form__field { display: flex; flex-direction: column; gap: 0.375rem; }
  .elanvi-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }

  .elanvi-form__label {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--elanvi-text, #2E2924);
  }

  .elanvi-form__input {
    padding: 0.75rem 1rem;
    border: 1px solid var(--elanvi-border, #E4DED5);
    border-radius: 12px;
    font-size: 1rem;
    color: var(--elanvi-text, #2E2924);
    background-color: var(--elanvi-white, #fff);
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    width: 100%;
  }

  .elanvi-form__input:focus {
    outline: none;
    border-color: var(--elanvi-gold, #B78A57);
    box-shadow: 0 0 0 3px rgba(183,138,87,0.15);
  }

  .elanvi-form__checkbox {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--elanvi-text, #2E2924);
    cursor: pointer;
  }

  .elanvi-address-form__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 0.5rem;
  }

  .elanvi-address-grid {
    display: grid;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }

  @media (min-width: 750px) {
    .elanvi-address-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 990px) {
    .elanvi-address-grid { grid-template-columns: repeat(3, 1fr); }
  }

  .elanvi-address-card {
    background: var(--elanvi-white, #fff);
    border: 1px solid var(--elanvi-border, #E4DED5);
    border-radius: 16px;
    padding: 1.25rem;
    position: relative;
  }

  .elanvi-address-card__default {
    display: inline-flex;
    align-items: center;
    padding: 0.2rem 0.625rem;
    border-radius: 9999px;
    font-size: 0.6875rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    background-color: rgba(183,138,87,0.1);
    color: var(--elanvi-gold, #B78A57);
    border: 1px solid rgba(183,138,87,0.3);
    margin-bottom: 0.875rem;
  }

  .elanvi-address-card__body {
    font-size: 0.875rem;
    color: var(--elanvi-text-muted, #5A5147);
    font-style: normal;
    line-height: 1.65;
    margin-bottom: 0.875rem;
  }

  .elanvi-address-card__actions {
    display: flex;
    gap: 0.875rem;
    border-top: 1px solid var(--elanvi-border, #E4DED5);
    padding-top: 0.875rem;
  }

  .elanvi-address-card__edit-btn {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--elanvi-gold, #B78A57);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .elanvi-address-card__delete-btn {
    font-size: 0.8125rem;
    font-weight: 500;
    color: #c0392b;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .elanvi-address-delete-form { display: inline; }

  .elanvi-address-edit {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--elanvi-border, #E4DED5);
  }

  .elanvi-account-empty {
    background: var(--elanvi-bg-light, #FAF8F4);
    border: 1px solid var(--elanvi-border, #E4DED5);
    border-radius: 16px;
    padding: 3rem 1.5rem;
    text-align: center;
    margin-bottom: 2rem;
  }

  .elanvi-account-empty__text { color: var(--elanvi-text-muted, #5A5147); margin: 0; }

  .elanvi-account-back {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.875rem;
    color: var(--elanvi-gold, #B78A57);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Customer Addresses",
  "tag": "div",
  "class": "elanvi-section",
  "enabled_on": {
    "templates": ["customers/addresses"]
  },
  "settings": []
}
{% endschema %}
