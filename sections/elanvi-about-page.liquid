{% stylesheet %}
/* =================================================================
   ELANVI ABOUT PAGE  (BEM: eap-)
   Uses global --elanvi-* tokens from elanvi-theme.css
   ================================================================= */

/* -- Page wrapper ------------------------------------------------- */
.eap {
  background-color: var(--elanvi-bg);
  color: var(--elanvi-text);
  font-family: var(--elanvi-font-sans);
  -webkit-font-smoothing: antialiased;
  overflow-x: hidden;
}

/* Eyebrow: slightly larger within the about page for readability */
.eap .elanvi-eyebrow {
  font-size: 0.6875rem;
  letter-spacing: 0.28em;
}
@media (min-width: 750px) {
  .eap .elanvi-eyebrow { font-size: 0.8125rem; }
}
/* Eyebrow on dark-background sections */
.eap-cta .elanvi-eyebrow { color: var(--elanvi-gold) !important; }

/* ==================================================================
   1. HERO
   ================================================================== */
.eap-hero {
  position: relative;
  overflow: hidden;
  min-height: 420px;
  display: flex;
  align-items: flex-end;
}
@media (min-width: 750px)  { .eap-hero { min-height: 580px; } }
@media (min-width: 1100px) { .eap-hero { min-height: 680px; } }

.eap-hero__media {
  position: absolute;
  inset: 0;
}
.eap-hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.eap-hero__media--placeholder {
  background: linear-gradient(160deg, #ebe6e1 0%, #c8bbb0 100%);
}
.eap-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(25, 20, 14, 0.82) 0%,
    rgba(25, 20, 14, 0.45) 45%,
    rgba(25, 20, 14, 0.12) 100%
  );
}
.eap-hero__inner {
  position: relative;
  z-index: 2;
  width: 100%;
  max-width: 720px;
  margin-inline: auto;
  text-align: center;
  padding: 3rem 1.5rem 4rem;
}
@media (min-width: 750px) { .eap-hero__inner { padding: 3rem 2.5rem 5.5rem; } }
.eap-hero__inner .elanvi-eyebrow { color: var(--elanvi-gold); }
.eap-hero__title {
  color: #fff;
  margin-top: 0.75rem !important;
  font-size: clamp(1.625rem, 6vw, 3.5rem);
}
.eap-hero__sub {
  margin-top: 1rem;
  font-size: clamp(0.875rem, 2.5vw, 1.125rem);
  color: rgba(255, 255, 255, 0.82);
  line-height: 1.75;
  max-width: 580px;
  margin-inline: auto;
}
.eap-hero__scroll {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 42px;
  height: 42px;
  border-radius: 50%;
  border: 1px solid rgba(255,255,255,0.4);
  color: #fff;
  margin-top: 2rem;
  text-decoration: none;
  transition: border-color var(--elanvi-transition), background-color var(--elanvi-transition);
  animation: eap-bob 2.2s ease-in-out infinite;
}
.eap-hero__scroll:hover {
  border-color: var(--elanvi-gold);
  background-color: rgba(200, 157, 108, 0.15);
}
@keyframes eap-bob {
  0%, 100% { transform: translateY(0); }
  50%       { transform: translateY(6px); }
}

/* ==================================================================
   2. MISSION PILLARS
   ================================================================== */
.eap-mission {
  background-color: var(--elanvi-bg-cream);
  border-top: 1px solid var(--elanvi-border);
  border-bottom: 1px solid var(--elanvi-border);
}
.eap-mission__header {
  text-align: center;
  max-width: 620px;
  margin: 0 auto;
  padding: 3.5rem 1.5rem 0;
}
@media (min-width: 750px) {
  .eap-mission__header { padding: 5rem 2.5rem 0; }
}
.eap-mission__heading { margin-top: 0.875rem !important; }
.eap-mission__heading::after {
  content: '';
  display: block;
  width: 40px;
  height: 2px;
  background: linear-gradient(90deg, var(--elanvi-gold), rgba(200, 157, 108, 0.25));
  margin: 1rem auto 0;
  border-radius: 2px;
}
.eap-mission__inner {
  max-width: 1200px;
  margin-inline: auto;
  padding: 2.5rem 1.5rem 4rem;
  display: grid;
  grid-template-columns: 1fr;
  gap: 1.75rem;
}
@media (min-width: 750px) {
  .eap-mission__inner {
    grid-template-columns: repeat(3, 1fr);
    padding: 2.5rem 2.5rem 5rem;
    gap: 2.5rem;
  }
}
.eap-mission__block {
  text-align: center;
  padding: 1.75rem 1.25rem 1.5rem;
  background: var(--elanvi-bg-card);
  border-radius: var(--elanvi-radius);
  border: 1px solid var(--elanvi-border);
  border-top: 3px solid var(--elanvi-gold);
  transition: box-shadow var(--elanvi-transition), transform var(--elanvi-transition), border-color var(--elanvi-transition);
}
@media (min-width: 750px) {
  .eap-mission__block { padding: 2.25rem 1.5rem 2rem; }
}
@media (hover: hover) {
  .eap-mission__block:hover {
    box-shadow: 0 12px 36px rgba(35, 32, 27, 0.1);
    transform: translateY(-5px);
    border-color: var(--elanvi-gold);
    border-top-color: var(--elanvi-gold);
  }
}
.eap-mission__icon {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background-color: rgba(200, 157, 108, 0.12);
  color: var(--elanvi-gold);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 1.25rem;
}
.eap-mission__title {
  font-family: var(--elanvi-font-serif);
  font-size: 1.25rem;
  color: var(--elanvi-text);
  margin: 0 0 0.625rem;
}
@media (min-width: 750px) { .eap-mission__title { font-size: 1.375rem; } }
.eap-mission__body {
  font-size: 0.9375rem;
  color: var(--elanvi-text-muted);
  line-height: 1.72;
  margin: 0;
}

/* ==================================================================
   3. BRAND STORY
   ================================================================== */
.eap-story {
  padding: 4rem 1.5rem;
  background: linear-gradient(175deg, var(--elanvi-bg) 0%, rgba(235, 230, 225, 0.3) 100%);
}
@media (min-width: 750px) { .eap-story { padding: 5.5rem 2.5rem; } }
.eap-story__inner {
  max-width: 1200px;
  margin-inline: auto;
  display: grid;
  grid-template-columns: 1fr;
  gap: 2.5rem;
  align-items: center;
}
@media (min-width: 900px) {
  .eap-story__inner {
    grid-template-columns: 1fr 1fr;
    gap: 5rem;
  }
}
.eap-story__heading { margin-top: 0.875rem !important; }
.eap-story__body {
  margin-top: 1.375rem;
  font-size: 1rem;
  color: var(--elanvi-text-soft);
  line-height: 1.82;
}
@media (min-width: 750px) { .eap-story__body { font-size: 1.0625rem; } }
.eap-story__cta { margin-top: 2.25rem; }
@media (min-width: 900px) {
  .eap-story__text {
    padding-left: 2.5rem;
    border-left: 2px solid rgba(200, 157, 108, 0.35);
  }
}
.eap-story__media {
  border-radius: var(--elanvi-radius-lg);
  overflow: hidden;
  aspect-ratio: 3 / 2;
  box-shadow: 0 12px 40px rgba(35, 32, 27, 0.08);
}
@media (min-width: 900px) {
  .eap-story__media {
    aspect-ratio: 4 / 5;
    box-shadow: 0 20px 60px rgba(35, 32, 27, 0.1);
  }
}
.eap-story__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.6s ease;
}
.eap-story__media:hover .eap-story__img { transform: scale(1.04); }
.eap-story__placeholder {
  width: 100%;
  height: 100%;
  min-height: 220px;
  background: linear-gradient(155deg, var(--elanvi-bg-cream) 0%, #c8bbb0 100%);
}
@media (min-width: 900px) {
  .eap-story__placeholder { min-height: 440px; }
}

/* ==================================================================
   4. JOURNEY TIMELINE
   ================================================================== */
.eap-timeline {
  background-color: var(--elanvi-bg-cream);
  padding: 4rem 1.5rem;
  border-top: 1px solid var(--elanvi-border);
  border-bottom: 1px solid var(--elanvi-border);
  position: relative;
  overflow: hidden;
}
.eap-timeline::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(200, 157, 108, 0.08) 0%, transparent 55%);
  pointer-events: none;
}
@media (min-width: 750px) { .eap-timeline { padding: 5.5rem 2.5rem; } }
.eap-timeline__inner {
  max-width: 1100px;
  margin-inline: auto;
  position: relative;
  z-index: 1;
}
.eap-timeline__header { text-align: center; margin-bottom: 2.5rem; }
.eap-timeline__heading { margin-top: 0.875rem !important; }
.eap-timeline__heading::after {
  content: '';
  display: block;
  width: 40px;
  height: 2px;
  background: linear-gradient(90deg, var(--elanvi-gold), rgba(200, 157, 108, 0.25));
  margin: 1rem auto 0;
  border-radius: 2px;
}
.eap-timeline__track {
  display: flex;
  flex-direction: column;
  gap: 0;
  position: relative;
}
.eap-timeline__track::before {
  content: '';
  position: absolute;
  left: 18px;
  top: 0;
  bottom: 0;
  width: 2px;
  background: linear-gradient(to bottom, var(--elanvi-gold), transparent);
}
@media (min-width: 750px) {
  .eap-timeline__track { flex-direction: row; align-items: flex-start; }
  .eap-timeline__track::before {
    left: 0; right: 0; top: 18px; bottom: auto;
    width: auto; height: 2px;
    background: linear-gradient(to right, var(--elanvi-gold), rgba(200,157,108,0.2));
  }
}
.eap-timeline__item {
  display: flex;
  align-items: flex-start;
  gap: 1rem;
  padding-bottom: 2rem;
  padding-left: 0;
  flex: 1;
  position: relative;
}
.eap-timeline__item:last-child { padding-bottom: 0; }
@media (min-width: 750px) {
  .eap-timeline__item {
    flex-direction: column;
    align-items: center;
    padding-bottom: 0;
    text-align: center;
    padding-inline: 1rem;
  }
}
.eap-timeline__dot {
  flex-shrink: 0;
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background-color: var(--elanvi-gold);
  border: 3px solid var(--elanvi-bg-cream);
  box-shadow: 0 0 0 2px var(--elanvi-gold);
  position: relative;
  z-index: 1;
  margin-top: 2px;
}
@media (min-width: 750px) {
  .eap-timeline__dot {
    width: 38px;
    height: 38px;
    margin-top: 0;
    margin-bottom: 1.5rem;
  }
}
.eap-timeline__card { flex: 1; }
@media (min-width: 750px) { .eap-timeline__card { flex: none; } }
.eap-timeline__year {
  font-family: var(--elanvi-font-serif);
  font-size: 1.125rem;
  color: var(--elanvi-gold);
  font-style: italic;
  display: block;
  margin-bottom: 0.25rem;
}
@media (min-width: 750px) { .eap-timeline__year { font-size: 1.375rem; margin-bottom: 0.375rem; } }
.eap-timeline__event {
  font-family: var(--elanvi-font-serif);
  font-size: 1rem;
  color: var(--elanvi-text);
  margin: 0 0 0.375rem;
}
@media (min-width: 750px) { .eap-timeline__event { font-size: 1.125rem; margin-bottom: 0.5rem; } }
.eap-timeline__desc {
  font-size: 0.9rem;
  color: var(--elanvi-text-muted);
  line-height: 1.7;
  margin: 0;
}

/* ==================================================================
   5. STATS BAR
   ================================================================== */
.eap-stats {
  background-color: var(--elanvi-text);
  padding: 4rem 1.5rem;
  position: relative;
  overflow: hidden;
}
.eap-stats::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse at 50% -10%, rgba(200, 157, 108, 0.22) 0%, transparent 55%),
    radial-gradient(ellipse at 50% 110%, rgba(200, 157, 108, 0.10) 0%, transparent 50%);
  pointer-events: none;
}
@media (min-width: 750px) { .eap-stats { padding: 5.5rem 2.5rem; } }

/* Header */
.eap-stats__header {
  text-align: center;
  margin-bottom: 2.5rem;
  position: relative;
  z-index: 1;
}
.eap-stats__eyebrow {
  color: var(--elanvi-gold) !important;
  opacity: 0.8;
}
.eap-stats__heading {
  font-family: var(--elanvi-font-serif);
  font-size: clamp(1.5rem, 3vw, 2.25rem);
  color: #fff;
  margin: 0.75rem 0 0;
  font-weight: 400;
  letter-spacing: -0.01em;
}
.eap-stats__heading::after {
  content: '';
  display: block;
  width: 40px;
  height: 2px;
  background: linear-gradient(90deg, var(--elanvi-gold), rgba(200, 157, 108, 0.2));
  margin: 1rem auto 0;
  border-radius: 2px;
}

/* Grid */
.eap-stats__inner {
  max-width: 1040px;
  margin-inline: auto;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
  position: relative;
  z-index: 1;
}
@media (min-width: 700px) {
  .eap-stats__inner {
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }
}

/* Stat card */
.eap-stat {
  text-align: center;
  padding: 1.5rem 1rem;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid rgba(200, 157, 108, 0.18);
  border-radius: var(--elanvi-radius);
  display: flex;
  flex-direction: column;
  align-items: center;
  transition: background var(--elanvi-transition), border-color var(--elanvi-transition), transform var(--elanvi-transition);
}
@media (hover: hover) {
  .eap-stat:hover {
    background: rgba(200, 157, 108, 0.09);
    border-color: rgba(200, 157, 108, 0.45);
    transform: translateY(-4px);
  }
}
@media (min-width: 700px) {
  .eap-stat {
    border-radius: 0;
    border: none;
    background: none;
    padding: 1.5rem 2rem;
    position: relative;
  }
  .eap-stat + .eap-stat::before {
    content: '';
    position: absolute;
    left: 0;
    top: 20%;
    bottom: 20%;
    width: 1px;
    background: linear-gradient(to bottom, transparent, rgba(200, 157, 108, 0.35), transparent);
  }
}
@media (hover: hover) and (min-width: 700px) {
  .eap-stat:hover {
    background: rgba(200, 157, 108, 0.06);
    border-color: transparent;
    border-radius: var(--elanvi-radius-sm);
    transform: translateY(-3px);
  }
}

/* Icon */
.eap-stat__icon {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 1px solid rgba(200, 157, 108, 0.3);
  background: rgba(200, 157, 108, 0.08);
  color: var(--elanvi-gold);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1rem;
}

/* Number */
.eap-stat__number {
  font-family: var(--elanvi-font-serif);
  font-size: clamp(2rem, 8vw, 3.5rem);
  color: var(--elanvi-gold);
  margin: 0;
  line-height: 1;
  text-shadow: 0 0 40px rgba(200, 157, 108, 0.4);
  letter-spacing: -0.02em;
}

/* Gold divider line between number and label */
.eap-stat__divider {
  display: block;
  width: 28px;
  height: 1px;
  background: linear-gradient(90deg, transparent, var(--elanvi-gold), transparent);
  margin: 0.875rem auto;
  opacity: 0.6;
}

/* Label */
.eap-stat__label {
  font-size: 0.6875rem;
  font-weight: 500;
  color: rgba(232, 224, 214, 0.92);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin: 0;
  line-height: 1.5;
}
@media (min-width: 700px) {
  .eap-stat__label {
    font-size: 0.75rem;
    letter-spacing: 0.18em;
  }
}

/* ==================================================================
   6. FOUNDER SPOTLIGHT
   ================================================================== */
.eap-founder {
  padding: 4rem 1.5rem;
  background-color: var(--elanvi-bg);
  position: relative;
  overflow: hidden;
}
.eap-founder::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 75% 50%, rgba(200, 157, 108, 0.07) 0%, transparent 55%);
  pointer-events: none;
}
@media (min-width: 750px) { .eap-founder { padding: 5.5rem 2.5rem; } }
.eap-founder__inner {
  max-width: 1100px;
  margin-inline: auto;
  display: grid;
  grid-template-columns: 1fr;
  gap: 2.5rem;
  align-items: center;
  position: relative;
  z-index: 1;
}
@media (min-width: 900px) {
  .eap-founder__inner {
    grid-template-columns: 400px 1fr;
    gap: 5rem;
  }
}
.eap-founder__media {
  border-radius: var(--elanvi-radius-lg);
  overflow: hidden;
  aspect-ratio: 3 / 2;
  box-shadow: 0 12px 40px rgba(35, 32, 27, 0.1);
}
@media (min-width: 900px) {
  .eap-founder__media {
    aspect-ratio: 8 / 9;
    box-shadow: 0 24px 64px rgba(35, 32, 27, 0.12);
  }
}
.eap-founder__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: top center;
  display: block;
  transition: transform 0.6s ease;
}
.eap-founder__media:hover .eap-founder__img { transform: scale(1.03); }
.eap-founder__placeholder {
  width: 100%;
  height: 100%;
  min-height: 220px;
  background: linear-gradient(150deg, var(--elanvi-bg-cream) 0%, #d9cfc6 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}
@media (min-width: 900px) {
  .eap-founder__placeholder { min-height: 420px; }
}
.eap-founder__quote {
  font-family: var(--elanvi-font-serif);
  font-size: clamp(1rem, 2vw, 1.5rem);
  line-height: 1.65;
  color: var(--elanvi-text);
  font-style: italic;
  margin: 1.25rem 0 0;
  padding: 1.25rem 1.25rem;
  border: none;
  border-left: 3px solid var(--elanvi-gold);
  border-radius: 0 var(--elanvi-radius-sm) var(--elanvi-radius-sm) 0;
  background: linear-gradient(135deg, rgba(200, 157, 108, 0.08) 0%, rgba(200, 157, 108, 0.02) 100%);
  position: relative;
}
@media (min-width: 750px) {
  .eap-founder__quote { padding: 1.5rem 1.75rem; margin-top: 1.5rem; }
}
.eap-founder__quote-mark {
  color: var(--elanvi-gold);
  display: block;
  margin-bottom: 0.25rem;
}
.eap-founder__attribution {
  display: flex;
  flex-direction: column;
  gap: 0.2rem;
  margin-top: 1.75rem;
  padding-top: 1.25rem;
  border-top: 1px solid var(--elanvi-border);
}
.eap-founder__name {
  font-family: var(--elanvi-font-serif);
  font-size: 1.0625rem;
  color: var(--elanvi-text);
  font-weight: 600;
}
.eap-founder__role {
  font-size: 0.8125rem;
  color: var(--elanvi-gold);
  text-transform: uppercase;
  letter-spacing: 0.1em;
}
.eap-founder__bio {
  margin-top: 1.375rem;
  font-size: 0.9375rem;
  color: var(--elanvi-text-muted);
  line-height: 1.78;
}

/* ==================================================================
   7. VALUES GRID
   ================================================================== */
.eap-values {
  padding: 4rem 1.5rem;
  background-color: var(--elanvi-bg-cream);
  border-top: 1px solid var(--elanvi-border);
  position: relative;
  overflow: hidden;
}
.eap-values::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse at 50% 0%, rgba(200, 157, 108, 0.07) 0%, transparent 50%);
  pointer-events: none;
}
@media (min-width: 750px) { .eap-values { padding: 5.5rem 2.5rem; } }
.eap-values__inner { max-width: 1200px; margin-inline: auto; }
.eap-values__header { text-align: center; margin-bottom: 2.5rem; position: relative; z-index: 1; }
.eap-values__heading { margin-top: 0.875rem !important; }
.eap-values__heading::after {
  content: '';
  display: block;
  width: 40px;
  height: 2px;
  background: linear-gradient(90deg, var(--elanvi-gold), rgba(200, 157, 108, 0.25));
  margin: 1rem auto 0;
  border-radius: 2px;
}
.eap-values__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
  position: relative;
  z-index: 1;
}
@media (min-width: 600px) { .eap-values__grid { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; } }
@media (min-width: 990px) { .eap-values__grid { grid-template-columns: repeat(4, 1fr); gap: 1.5rem; } }
.eap-value-card {
  background-color: var(--elanvi-bg-card);
  border: 1px solid var(--elanvi-border);
  border-top: 3px solid var(--elanvi-gold);
  border-radius: var(--elanvi-radius);
  padding: 1.5rem 1.25rem 1.25rem;
  transition: box-shadow var(--elanvi-transition), transform var(--elanvi-transition), border-color var(--elanvi-transition);
}
@media (min-width: 600px) {
  .eap-value-card { padding: 2.25rem 1.5rem 2rem; }
}
@media (hover: hover) {
  .eap-value-card:hover {
    box-shadow: 0 12px 40px rgba(35, 32, 27, 0.11);
    transform: translateY(-5px);
    border-color: var(--elanvi-gold);
    border-top-color: var(--elanvi-gold);
  }
}
.eap-value-card__icon {
  width: 48px;
  height: 48px;
  border-radius: 50%;
  background-color: rgba(200, 157, 108, 0.1);
  color: var(--elanvi-gold);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 1.25rem;
}
.eap-value-card__title {
  font-family: var(--elanvi-font-serif);
  font-size: 1.125rem;
  color: var(--elanvi-text);
  margin: 0 0 0.625rem;
}
.eap-value-card__body {
  font-size: 0.9375rem;
  color: var(--elanvi-text-muted);
  line-height: 1.72;
  margin: 0;
}

/* ==================================================================
   8. CERTIFICATIONS STRIP
   ================================================================== */
.eap-certs {
  background-color: var(--elanvi-bg);
  border-top: 1px solid var(--elanvi-border);
  border-bottom: 1px solid var(--elanvi-border);
  padding: 2.5rem 1.5rem;
}
@media (min-width: 750px) { .eap-certs { padding: 3.5rem 2.5rem; } }
.eap-certs__inner {
  max-width: 1100px;
  margin-inline: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.75rem;
}
.eap-certs__label {
  font-size: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.25em;
  color: var(--elanvi-green);
  font-weight: 600;
  margin: 0;
}
.eap-certs__badges {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 0.875rem;
}
.eap-cert {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--elanvi-bg-card);
  border: 1px solid var(--elanvi-border);
  border-radius: 100px;
  padding: 0.5rem 1.125rem;
  font-size: 0.8125rem;
  color: var(--elanvi-text-muted);
  transition: border-color var(--elanvi-transition), box-shadow var(--elanvi-transition);
  white-space: nowrap;
}
.eap-cert:hover {
  border-color: var(--elanvi-gold);
  box-shadow: 0 2px 12px rgba(200, 157, 108, 0.15);
}
.eap-cert__icon {
  color: var(--elanvi-gold);
  flex-shrink: 0;
  display: flex;
  align-items: center;
}

/* ==================================================================
   9. CTA STRIP
   ================================================================== */
.eap-cta {
  background-color: var(--elanvi-text);
  padding: 4rem 1.5rem;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.eap-cta::before {
  content: '';
  position: absolute;
  top: -30%;
  left: 50%;
  transform: translateX(-50%);
  width: 640px;
  height: 420px;
  background: radial-gradient(ellipse at center, rgba(200, 157, 108, 0.16) 0%, transparent 70%);
  pointer-events: none;
}
.eap-cta::after {
  content: '';
  position: absolute;
  bottom: -20%;
  left: 50%;
  transform: translateX(-50%);
  width: 320px;
  height: 200px;
  background: radial-gradient(ellipse at center, rgba(200, 157, 108, 0.08) 0%, transparent 70%);
  pointer-events: none;
}
@media (min-width: 750px) { .eap-cta { padding: 5.5rem 2.5rem; } }
.eap-cta__inner { max-width: 640px; margin-inline: auto; position: relative; z-index: 1; }
.eap-cta__eyebrow { color: var(--elanvi-gold) !important; margin-bottom: 1rem; }
.eap-cta__heading {
  color: #fff !important;
  margin: 0 0 1.25rem !important;
}
.eap-cta__sub {
  font-size: 1rem;
  color: rgba(232, 224, 214, 0.9);
  line-height: 1.75;
  margin: 0 0 2.5rem;
}
.eap-cta__buttons {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  gap: 0.75rem;
}
.eap-cta__buttons .elanvi-btn {
  width: 100%;
  justify-content: center;
}
@media (min-width: 480px) {
  .eap-cta__buttons {
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0.875rem;
  }
  .eap-cta__buttons .elanvi-btn { width: auto; }
}
.eap-cta .elanvi-btn--outline {
  color: var(--elanvi-gold);
  border-color: rgba(200, 157, 108, 0.5);
}
.eap-cta .elanvi-btn--outline:hover {
  border-color: var(--elanvi-gold);
  background-color: rgba(200, 157, 108, 0.08);
}
{% endstylesheet %}

