  {%- comment -%}──────────────────────────── 9. CTA STRIP ──────────────────────{%- endcomment -%}
  <div class="eap-cta">
    <div class="eap-cta__inner">
      <span class="elanvi-eyebrow eap-cta__eyebrow">{{ section.settings.cta_eyebrow | default: 'Begin Your Ritual' }}</span>
      <h2 class="elanvi-heading-md eap-cta__heading">
        {{ section.settings.cta_heading | default: 'Ready to experience the Elanvi difference?' }}
      </h2>
      <p class="eap-cta__sub">
        {{ section.settings.cta_sub | default: 'Join over 50,000 women who have made Elanvi part of their daily self-care practice.' }}
