{%- comment -%}
  Section: elanvi-about-page
  Full dedicated About Us page:
    1. Hero banner
    2. Mission pillars strip
    3. Brand story (text + image)
    4. Journey timeline
    5. Stats bar
    6. Founder spotlight
    7. Values grid
    8. Certifications strip
    9. CTA strip
{%- endcomment -%}

<div class="eap" id="elanvi-about-page">

  {%- comment -%}──────────────────────────── 1. HERO ────────────────────────────{%- endcomment -%}
  <div class="eap-hero">
    {%- if section.settings.hero_image != blank -%}
      <div class="eap-hero__media">
        <img
          src="{{ section.settings.hero_image | image_url: width: 1600 }}"
          alt="{{ section.settings.hero_image.alt | default: shop.name }}"
          loading="eager"
          fetchpriority="high"
          width="1600"
          height="640"
          class="eap-hero__img"
        >
        <div class="eap-hero__overlay" aria-hidden="true"></div>
      </div>
    {%- else -%}
      <div class="eap-hero__media eap-hero__media--placeholder" aria-hidden="true">
        <div class="eap-hero__overlay" aria-hidden="true"></div>
      </div>
    {%- endif -%}
    <div class="eap-hero__inner">
      <span class="elanvi-eyebrow">{{ section.settings.eyebrow | default: 'Our Story' }}</span>
      <h1 class="elanvi-heading-xl eap-hero__title">
        {{ section.settings.hero_heading | default: 'Science Rooted in Ancient Wisdom' }}
      </h1>
      <p class="eap-hero__sub">
        {{ section.settings.hero_body | default: 'Elanvi was born from a simple belief: that women above 30 deserve skincare as thoughtful and refined as they are. We weave centuries of Ayurvedic intelligence with cutting-edge dermatological science — creating rituals, not just products.' }}
      </p>
      <a href="#eap-story" class="eap-hero__scroll" aria-label="Scroll to our story">
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 3v14M3 10l7 7 7-7"/></svg>
      </a>
    </div>
  </div>

  {%- comment -%}──────────────────────────── 2. MISSION PILLARS ────────────────{%- endcomment -%}
  <div class="eap-mission">
    <div class="eap-mission__header">
      <span class="elanvi-eyebrow">{{ section.settings.mission_eyebrow | default: 'The Elanvi Way' }}</span>
      <h2 class="elanvi-heading-lg eap-mission__heading">
        {{ section.settings.mission_heading | default: 'Our Founding Principles' }}
      </h2>
    </div>
    <div class="eap-mission__inner">
      <div class="eap-mission__block">
        <div class="eap-mission__icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a9 9 0 0 1 9 9c0 4.97-9 13-9 13S3 15.97 3 11a9 9 0 0 1 9-9z"/><circle cx="12" cy="11" r="3"/></svg>
        </div>
        <h3 class="eap-mission__title">{{ section.settings.pillar_1_title | default: 'Ayurvedic Heritage' }}</h3>
        <p class="eap-mission__body">{{ section.settings.pillar_1_body | default: 'Every formula begins with time-honoured Ayurvedic botanicals — Ashwagandha, Kumkumadi, Saffron, and more — chosen for their proven efficacy on mature skin.' }}</p>
      </div>
      <div class="eap-mission__block">
        <div class="eap-mission__icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 3H5a2 2 0 0 0-2 2v4m6-6h10a2 2 0 0 1 2 2v4M9 3v18m0 0h10a2 2 0 0 0 2-2V9M9 21H5a2 2 0 0 1-2-2V9m0 0h18"/></svg>
        </div>
        <h3 class="eap-mission__title">{{ section.settings.pillar_2_title | default: 'Modern Science' }}</h3>
        <p class="eap-mission__body">{{ section.settings.pillar_2_body | default: 'Our R&D team pairs ancient actives with clinically validated peptides, retinoids, and hyaluronic acid complexes — delivering visible results without compromise.' }}</p>
      </div>
      <div class="eap-mission__block">
        <div class="eap-mission__icon" aria-hidden="true">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/><path d="M8 12l2.5 2.5L16 9"/></svg>
        </div>
        <h3 class="eap-mission__title">{{ section.settings.pillar_3_title | default: 'Luxury You Deserve' }}</h3>
        <p class="eap-mission__body">{{ section.settings.pillar_3_body | default: 'Premium textures, elegant packaging, and a sensorial ritual experience designed to make every morning and evening feel like a celebration of self.' }}</p>
      </div>
    </div>
  </div>

  {%- comment -%}──────────────────────────── 3. BRAND STORY ────────────────────{%- endcomment -%}
  <div class="eap-story" id="eap-story">
    <div class="eap-story__inner">
      <div class="eap-story__text">
        <span class="elanvi-eyebrow">{{ section.settings.story_eyebrow | default: 'Where it all began' }}</span>
        <h2 class="elanvi-heading-lg eap-story__heading">
          {{ section.settings.story_heading | default: 'A Kitchen Counter. A Real Problem. A Purpose.' }}
        </h2>
        <p class="eap-story__body">
          {{ section.settings.story_body_1 | default: 'In 2021, our founder Ananya noticed something that most skincare brands were ignoring: women in their 30s, 40s, and 50s were being offered the same products as teenagers. Generic formulas. Generic promises. No acknowledgment of the unique shifts that mature skin undergoes — hormonally, structurally, and environmentally.' }}
        </p>
        <p class="eap-story__body">
          {{ section.settings.story_body_2 | default: 'She spent two years working with Ayurvedic scholars in Kerala and dermatologists in Bengaluru, blending the two worlds into what is now Elanvi. The name itself derives from the Tamil word meaning "youthful, radiant, and full of life." Every product carries that intention.' }}
        </p>
        <a href="{{ routes.collections_url }}" class="elanvi-btn elanvi-btn--primary eap-story__cta">
          {{ section.settings.story_cta | default: 'Explore Our Products' }}
        </a>
      </div>
      <div class="eap-story__media">
        {%- if section.settings.story_image != blank -%}
          <img
            src="{{ section.settings.story_image | image_url: width: 800 }}"
            alt="{{ section.settings.story_image.alt | default: 'Elanvi brand story' }}"
            loading="lazy"
            width="800"
            height="900"
            class="eap-story__img"
          >
        {%- else -%}
          <div class="eap-story__placeholder" aria-hidden="true"></div>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- comment -%}──────────────────────────── 4. JOURNEY TIMELINE ───────────────{%- endcomment -%}
  <div class="eap-timeline">
    <div class="eap-timeline__inner">
      <div class="eap-timeline__header">
        <span class="elanvi-eyebrow">{{ section.settings.timeline_eyebrow | default: 'How we got here' }}</span>
        <h2 class="elanvi-heading-lg eap-timeline__heading">
          {{ section.settings.timeline_heading | default: 'Our Journey' }}
        </h2>
      </div>
      <div class="eap-timeline__track">

        <div class="eap-timeline__item">
          <div class="eap-timeline__dot" aria-hidden="true"></div>
          <div class="eap-timeline__card">
            <span class="eap-timeline__year">{{ section.settings.tl_1_year | default: '2021' }}</span>
            <h4 class="eap-timeline__event">{{ section.settings.tl_1_title | default: 'The Idea' }}</h4>
            <p class="eap-timeline__desc">{{ section.settings.tl_1_desc | default: 'Founder Ananya identifies a glaring gap in skincare for women above 30 and begins her deep-dive into Ayurvedic formulations.' }}</p>
          </div>
        </div>

        <div class="eap-timeline__item">
          <div class="eap-timeline__dot" aria-hidden="true"></div>
          <div class="eap-timeline__card">
            <span class="eap-timeline__year">{{ section.settings.tl_2_year | default: '2022' }}</span>
            <h4 class="eap-timeline__event">{{ section.settings.tl_2_title | default: 'Research & Formulation' }}</h4>
            <p class="eap-timeline__desc">{{ section.settings.tl_2_desc | default: 'Two years of collaboration with Ayurvedic scholars in Kerala and dermatologists in Bengaluru to perfect the first formula.' }}</p>
          </div>
        </div>

        <div class="eap-timeline__item">
          <div class="eap-timeline__dot" aria-hidden="true"></div>
          <div class="eap-timeline__card">
            <span class="eap-timeline__year">{{ section.settings.tl_3_year | default: '2023' }}</span>
            <h4 class="eap-timeline__event">{{ section.settings.tl_3_title | default: 'Launch' }}</h4>
            <p class="eap-timeline__desc">{{ section.settings.tl_3_desc | default: "Elanvi launches with the Neck &amp; Jawline Firming Cream — India's first premium Ayurvedic neck-care ritual for mature skin." }}</p>
          </div>
        </div>

        <div class="eap-timeline__item">
          <div class="eap-timeline__dot" aria-hidden="true"></div>
          <div class="eap-timeline__card">
            <span class="eap-timeline__year">{{ section.settings.tl_4_year | default: 'Today' }}</span>
            <h4 class="eap-timeline__event">{{ section.settings.tl_4_title | default: '50,000+ Women &amp; Growing' }}</h4>
            <p class="eap-timeline__desc">{{ section.settings.tl_4_desc | default: 'Stocked on Amazon, Nykaa, and available across India — with new formulations and a full ritual range on the horizon.' }}</p>
          </div>
        </div>

      </div>
    </div>
  </div>

  {%- comment -%}──────────────────────────── 5. STATS BAR ──────────────────────{%- endcomment -%}
  <div class="eap-stats">
    <div class="eap-stats__header">
      <span class="elanvi-eyebrow eap-stats__eyebrow">{{ section.settings.stats_eyebrow | default: 'By The Numbers' }}</span>
      <h2 class="eap-stats__heading">{{ section.settings.stats_heading | default: 'Trusted by Thousands' }}</h2>
    </div>
    <div class="eap-stats__inner">

      <div class="eap-stat">
        <div class="eap-stat__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a9 9 0 0 1 9 9c0 4.97-9 13-9 13S3 15.97 3 11a9 9 0 0 1 9-9z"/><circle cx="12" cy="11" r="3"/></svg>
        </div>
        <p class="eap-stat__number">{{ section.settings.stat_1_num | default: '30+' }}</p>
        <span class="eap-stat__divider" aria-hidden="true"></span>
        <p class="eap-stat__label">{{ section.settings.stat_1_label | default: 'Ayurvedic Actives' }}</p>
      </div>

      <div class="eap-stat">
        <div class="eap-stat__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <p class="eap-stat__number">{{ section.settings.stat_2_num | default: '50,000+' }}</p>
        <span class="eap-stat__divider" aria-hidden="true"></span>
        <p class="eap-stat__label">{{ section.settings.stat_2_label | default: 'Happy Customers' }}</p>
      </div>

      <div class="eap-stat">
        <div class="eap-stat__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        </div>
        <p class="eap-stat__number">{{ section.settings.stat_3_num | default: '4.8★' }}</p>
        <span class="eap-stat__divider" aria-hidden="true"></span>
        <p class="eap-stat__label">{{ section.settings.stat_3_label | default: 'Average Rating' }}</p>
      </div>

      <div class="eap-stat">
        <div class="eap-stat__icon" aria-hidden="true">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="M9 12l2 2 4-4"/></svg>
        </div>
        <p class="eap-stat__number">{{ section.settings.stat_4_num | default: '100%' }}</p>
        <span class="eap-stat__divider" aria-hidden="true"></span>
        <p class="eap-stat__label">{{ section.settings.stat_4_label | default: 'Cruelty-Free' }}</p>
      </div>

    </div>
  </div>

  {%- comment -%}──────────────────────────── 6. FOUNDER SPOTLIGHT ──────────────{%- endcomment -%}
  <div class="eap-founder">
    <div class="eap-founder__inner">
      <div class="eap-founder__media">
        {%- if section.settings.founder_image != blank -%}
          <img
            src="{{ section.settings.founder_image | image_url: width: 640 }}"
            alt="{{ section.settings.founder_image.alt | default: 'Founder of Elanvi' }}"
            loading="lazy"
            width="640"
            height="720"
            class="eap-founder__img"
          >
        {%- else -%}
          <div class="eap-founder__placeholder" aria-hidden="true">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="opacity:.3;color:#c89d6c"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
        {%- endif -%}
      </div>
      <div class="eap-founder__text">
        <span class="elanvi-eyebrow">{{ section.settings.founder_eyebrow | default: 'Meet the Founder' }}</span>
        <blockquote class="eap-founder__quote">
          <svg class="eap-founder__quote-mark" width="36" height="36" viewBox="0 0 36 36" fill="none" aria-hidden="true"><text x="0" y="32" font-family="Georgia, serif" font-size="52" fill="currentColor" opacity=".15">"</text></svg>
          {{ section.settings.founder_quote | default: 'I built Elanvi because I believe every woman above 30 deserves skincare that honours who she is today — not who she was at 20. This is not anti-ageing. This is pro-living.' }}
        </blockquote>
        <div class="eap-founder__attribution">
          <strong class="eap-founder__name">{{ section.settings.founder_name | default: 'Ananya Krishnan' }}</strong>
          <span class="eap-founder__role">{{ section.settings.founder_role | default: 'Founder &amp; CEO, Elanvi' }}</span>
        </div>
        <p class="eap-founder__bio">
          {{ section.settings.founder_bio | default: "With a background in biochemistry and a lifelong passion for Ayurveda, Ananya bridges two worlds most brands treat as separate. She leads Elanvi's product development and is personally involved in every formula that reaches your hands." }}
        </p>
      </div>
    </div>
  </div>

  {%- comment -%}──────────────────────────── 7. VALUES GRID ────────────────────{%- endcomment -%}
  <div class="eap-values">
    <div class="eap-values__inner">
      <div class="eap-values__header">
        <span class="elanvi-eyebrow">{{ section.settings.values_eyebrow | default: 'What we stand for' }}</span>
        <h2 class="elanvi-heading-lg eap-values__heading">
          {{ section.settings.values_heading | default: 'Our Core Values' }}
        </h2>
      </div>
      <div class="eap-values__grid">

        <div class="eap-value-card">
          <div class="eap-value-card__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <h3 class="eap-value-card__title">{{ section.settings.val_1_title | default: 'Safety First' }}</h3>
          <p class="eap-value-card__body">{{ section.settings.val_1_body | default: 'Dermatologically tested on Indian skin tones. Free from parabens, sulfates, mineral oil, and artificial colourants.' }}</p>
        </div>

        <div class="eap-value-card">
          <div class="eap-value-card__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 5.66-16.88 5.85m19.5 1.9c-3.5-.93-6.63-.82-8.94 0-2.58.92-5.01 2.86-7.44 6.32"/></svg>
          </div>
          <h3 class="eap-value-card__title">{{ section.settings.val_2_title | default: 'Sustainably Crafted' }}</h3>
          <p class="eap-value-card__body">{{ section.settings.val_2_body | default: 'Recyclable packaging, ethically sourced botanicals, and carbon-conscious manufacturing — because beauty should not cost the planet.' }}</p>
        </div>

        <div class="eap-value-card">
          <div class="eap-value-card__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <h3 class="eap-value-card__title">{{ section.settings.val_3_title | default: 'Women-First Philosophy' }}</h3>
          <p class="eap-value-card__body">{{ section.settings.val_3_body | default: 'Built by women, for women. We celebrate the beauty of ageing gracefully and reject the narrative that skin must be "fixed."' }}</p>
        </div>

        <div class="eap-value-card">
          <div class="eap-value-card__icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.46 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 4.44-1.14z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.46 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-4.44-1.14z"/></svg>
          </div>
          <h3 class="eap-value-card__title">{{ section.settings.val_4_title | default: 'Transparent Ingredients' }}</h3>
          <p class="eap-value-card__body">{{ section.settings.val_4_body | default: 'Full ingredient transparency on every product. No hidden chemicals. No misleading claims. Just honest, effective skincare.' }}</p>
        </div>

      </div>
    </div>
  </div>

  {%- comment -%}──────────────────────────── 8. CERTIFICATIONS STRIP ────────────{%- endcomment -%}
  <div class="eap-certs">
    <div class="eap-certs__inner">
      <p class="eap-certs__label">{{ section.settings.certs_label | default: 'Our Commitments' }}</p>
      <div class="eap-certs__badges">

        <div class="eap-cert">
          <div class="eap-cert__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          </div>
          <span>{{ section.settings.cert_1 | default: 'Dermatologically Tested' }}</span>
        </div>

        <div class="eap-cert">
          <div class="eap-cert__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          </div>
          <span>{{ section.settings.cert_2 | default: 'Cruelty-Free' }}</span>
        </div>

        <div class="eap-cert">
          <div class="eap-cert__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 5.66-16.88 5.85m19.5 1.9c-3.5-.93-6.63-.82-8.94 0-2.58.92-5.01 2.86-7.44 6.32"/></svg>
          </div>
          <span>{{ section.settings.cert_3 | default: 'Eco-Conscious Packaging' }}</span>
        </div>

        <div class="eap-cert">
          <div class="eap-cert__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a9 9 0 0 1 9 9c0 4.97-9 13-9 13S3 15.97 3 11a9 9 0 0 1 9-9z"/><circle cx="12" cy="11" r="3"/></svg>
          </div>
          <span>{{ section.settings.cert_4 | default: 'India-Made' }}</span>
        </div>

        <div class="eap-cert">
          <div class="eap-cert__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
          </div>
          <span>{{ section.settings.cert_5 | default: 'Women-Led Brand' }}</span>
        </div>

        <div class="eap-cert">
          <div class="eap-cert__icon" aria-hidden="true">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.46 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 4.44-1.14z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.46 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-4.44-1.14z"/></svg>
          </div>
          <span>{{ section.settings.cert_6 | default: 'Paraben-Free Formula' }}</span>
        </div>

      </div>
