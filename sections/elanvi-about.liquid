{% comment %}
  Section: elanvi-about
  Brand story / About section with heading, body text, eco badges, and CTAs.
{% endcomment %}

<section class="elanvi-about" id="elanvi-about">
  <div class="elanvi-about__inner">

    <div class="elanvi-about__text">
      {%- if section.settings.heading != blank -%}
        <h2 class="elanvi-heading-lg">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <p class="elanvi-about__body">{{ section.settings.body }}</p>
      {%- endif -%}

      {%- if section.settings.badge_1 != blank or section.settings.badge_2 != blank or section.settings.badge_3 != blank -%}
        <div class="elanvi-about__badges">
          {%- if section.settings.badge_1 != blank -%}<span>{{ section.settings.badge_1 }}</span>{%- endif -%}
          {%- if section.settings.badge_2 != blank -%}<span>{{ section.settings.badge_2 }}</span>{%- endif -%}
          {%- if section.settings.badge_3 != blank -%}<span>{{ section.settings.badge_3 }}</span>{%- endif -%}
        </div>
      {%- endif -%}
    </div>

    <div class="elanvi-about__video">
      <video
        src="https://cdn.shopify.com/videos/c/o/v/1d7b810e3fb14e9fb27ebeca3e95d054.mp4"
        autoplay
        loop
        muted
        playsinline
        class="elanvi-about__video-player"
      ></video>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Elanvi — About",
  "tag": "div",
  "class": "elanvi-section",
  "settings": [
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Elanvi is building skincare for women above 30 years."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body Text",
      "default": "Thoughtful, elegant, age-smart skincare that honors Ayurvedic heritage and modern science. Every formula is crafted to nurture mature skin with dignity and grace."
    },
    {
      "type": "header",
      "content": "Trust Badges"
    },
    {
      "type": "text",
      "id": "badge_1",
      "label": "Badge 1",
      "default": "🌱 Cruelty-free"
    },
    {
      "type": "text",
      "id": "badge_2",
      "label": "Badge 2",
      "default": "💧 Clean ingredients"
    },
    {
      "type": "text",
      "id": "badge_3",
      "label": "Badge 3",
      "default": "♻️ Recyclable packaging"
    },
  ],
  "presets": [
    {
      "name": "Elanvi About"
    }
  ]
}
{% endschema %}
