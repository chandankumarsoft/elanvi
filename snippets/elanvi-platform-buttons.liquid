{% comment %}
  Snippet: elanvi-platform-buttons
  Renders external platform CTA buttons (Amazon, Nykaa, Flipkart).
  Each button opens the redirect modal before navigating.

  Parameters:
    amazon_url   {String} — Amazon product URL (optional)
    nykaa_url    {String} — Nykaa product URL (optional)
    flipkart_url {String} — Flipkart product URL (optional)
    label        {String} — Label text above buttons
    trust_1      {String} — Trust indicator 1
    trust_2      {String} — Trust indicator 2
    trust_3      {String} — Trust indicator 3
{% endcomment %}

<div class="elanvi-platforms">
    {%- if label != blank -%}
      <p class="elanvi-platforms__label">{{ label }}</p>
    {%- endif -%}

    <div class="elanvi-platforms__row">

      <button
        class="elanvi-platform-btn elanvi-platform-btn--amazon{%- if amazon_url == blank %} elanvi-platform-btn--inactive{%- endif %}"
        type="button"
        {%- if amazon_url != blank %}
          data-platform-url="{{ amazon_url | escape }}"
          data-platform-store="Amazon"
        {%- else %}
          disabled
          aria-disabled="true"
        {%- endif %}
        aria-label="Order now at Amazon"
      >
        <img
          src="{{ 'amazonorderbutton.png' | asset_url }}"
          alt="Order now at Amazon"
          class="elanvi-amazon-img"
          loading="lazy"
          decoding="async"
        >
      </button>

      <button
        class="elanvi-platform-btn elanvi-platform-btn--nykaa{%- if nykaa_url == blank %} elanvi-platform-btn--inactive{%- endif %}"
        type="button"
        {%- if nykaa_url != blank %}
          data-platform-url="{{ nykaa_url | escape }}"
          data-platform-store="Nykaa"
        {%- else %}
          disabled
          aria-disabled="true"
        {%- endif %}
        aria-label="Order now at nykaa.com"
      >
        <img
          src="{{ 'nykaaorderbutton.png' | asset_url }}"
          alt="Order now at Nykaa"
          class="elanvi-nykaa-img"
          loading="lazy"
          decoding="async"
        >
      </button>

      {%- if flipkart_url != blank -%}
        <button
          class="elanvi-platform-btn elanvi-platform-btn--flipkart"
          type="button"
          data-platform-url="{{ flipkart_url | escape }}"
          data-platform-store="Flipkart"
          aria-label="Buy on Flipkart"
        >
          <span class="elanvi-platform-btn__shine" aria-hidden="true"></span>
          <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
            <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15H8v-2h2v2zm0-4H8V7h2v6zm4 4h-2v-6h2v6zm0-8h-2V7h2v2z"/>
          </svg>
          Flipkart
        </button>
      {%- endif -%}

    </div>

    {%- if trust_1 != blank or trust_2 != blank or trust_3 != blank -%}
      <div class="elanvi-platforms__trust">
        {%- if trust_1 != blank -%}<span>{{ trust_1 }}</span>{%- endif -%}
        {%- if trust_2 != blank -%}<span>{{ trust_2 }}</span>{%- endif -%}
        {%- if trust_3 != blank -%}<span>{{ trust_3 }}</span>{%- endif -%}
      </div>
    {%- endif -%}
  </div>
